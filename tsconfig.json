{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "declaration": false,
    "types": ["node"]
  },
  "include": ["src", "esbuild.config.mjs", "vitest.config.ts"]
}
